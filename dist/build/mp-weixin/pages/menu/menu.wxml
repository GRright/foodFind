></view></view></view><view class="action-bar pop-in data-v-c2c1b298" style="animation-delay:0.15s"><view class="gen-btn data-v-c2c1b298" bindtap="{{j}}"><text class="gen-icon data-v-c2c1b298">✦</text><text class="gen-text data-v-c2c1b298">生成本周菜单</text></view><text wx:if="{{k}}" class="gen-hint data-v-c2c1b298">已生成 · {{l}}</text></view><scroll-view scroll-y class="meal-scroll data-v-c2c1b298" style="{{'height:' + q}}"><view wx:if="{{m}}" class="day-meals data-v-c2c1b298"><view class="day-label bounce-in data-v-c2c1b298"><text class="dl-date data-v-c2c1b298">{{n}}</text><text class="dl-cal data-v-c2c1b298">{{o}} kcal</text></view><view wx:for="{{p}}" wx:for-item="meal" wx:key="e" class="meal-section data-v-c2c1b298" style="{{'animation-delay:' + meal.f + ';' + 'animation:slideUp .45s ease forwards;opacity:0'}}"><view class="meal-header data-v-c2c1b298"><view class="mh-left data-v-c2c1b298"><text class="mh-icon data-v-c2c1b298">{{meal.a}}</text><text class="mh-title data-v-c2c1b298">{{meal.b}}</text></view><text class="mh-cal data-v-c2c1b298">{{meal.c}} kcal</text></view><view class="food-row data-v-c2c1b298"><view wx:for="{{meal.d}}" wx:for-item="food" wx:key="d" class="food-card data-v-c2c1b298" bindtap="{{food.e}}" style="{{'animation-delay:' + food.f + ';' + 'animation:popIn .4s cubic-bezier(.175,.885,.32,1.275) forwards;opacity:0'}}"><view class="fc-icon-wrap data-v-c2c1b298"><text class="fc-icon data-v-c2c1b298">{{food.a}}</text></view><text class="fc-name data-v-c2c1b298">{{food.b}}</text><text class="fc-kcal data-v-c2c1b298">{{food.c}} kcal</text></view></view></view></view><view wx:else class="empty-state scale-in data-v-c2c1b298"><text class="empty-icon data-v-c2c1b298">📅</text><text class="empty-title data-v-c2c1b298">该日暂无菜单</text><text class="empty-hint data-v-c2c1b298">点击上方「生成本周菜单」一键规划</text></view><view class="bottom-spacer data-v-c2c1b298"></view></scroll-view></view>