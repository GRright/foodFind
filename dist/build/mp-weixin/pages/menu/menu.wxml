<view class="{{['page', 'data-v-2dfe9fce', s && 'page-enter']}}"><view class="header fade-in data-v-2dfe9fce"><text class="header-title data-v-2dfe9fce">一周菜单</text><text class="header-sub data-v-2dfe9fce">点击日期查看 · 智能荤素搭配</text></view><view wx:if="{{a}}" class="spark-banner pop-in data-v-2dfe9fce" style="animation-delay:0.1s;opacity:0"><view class="spark-icon-wrap data-v-2dfe9fce"><text class="spark-emoji data-v-2dfe9fce">🔥</text></view><view class="spark-info data-v-2dfe9fce"><text class="spark-main data-v-2dfe9fce">{{b}}天连续互动</text><text class="spark-sub data-v-2dfe9fce">分享{{c}}天 · 打开{{d}}次</text></view><view wx:if="{{e}}" class="spark-badge data-v-2dfe9fce"><text class="badge-txt data-v-2dfe9fce">💎</text></view></view><view class="calendar-wrap slide-up data-v-2dfe9fce" style="animation-delay:0.08s"><view class="cal-nav data-v-2dfe9fce"><view class="nav-btn data-v-2dfe9fce" bindtap="{{f}}"><text class="nav-arrow data-v-2dfe9fce">◀</text><text class="nav-txt data-v-2dfe9fce">上一周</text></view><text class="cal-month data-v-2dfe9fce">{{g}}</text><view class="nav-btn data-v-2dfe9fce" bindtap="{{h}}"><text class="nav-txt data-v-2dfe9fce">下一周</text><text class="nav-arrow data-v-2dfe9fce">▶</text></view></view><view class="week-row data-v-2dfe9fce"><view wx:for="{{i}}" wx:for-item="d" wx:key="j" class="{{['day-cell', 'data-v-2dfe9fce', d.f && 'active', d.g && 'is-today', d.h && 'has-data', d.i && 'has-spark']}}" bindtap="{{d.k}}"><text class="day-week data-v-2dfe9fce">{{d.a}}</text><text class="day-num data-v-2dfe9fce">{{d.b}}</text><view wx:if="{{d.c}}" class="spark-icon data-v-2dfe9fce"><text class="si-txt data-v-2dfe9fce">🔥</text></view><view wx:elif="{{d.d}}" class="spark-icon double data-v-2dfe9fce"><text class="si-txt data-v-2dfe9fce">🔥🔥</text></view><view wx:if="{{d.e}}" class="dot-row data-v-2dfe9fce"><view class="nutri-dot b-dot data-v-2dfe9fce"></view><view class="nutri-dot l-dot data-v-2dfe9fce"></view><view class="nutri-dot d-dot data-v-2dfe9fce"></view></view></view></view></view><view class="action-bar pop-in data-v-2dfe9fce" style="animation-delay:0.15s"><view class="gen-btn data-v-2dfe9fce" bindtap="{{j}}"><text class="gen-icon data-v-2dfe9fce">✦</text><text class="gen-text data-v-2dfe9fce">生成本周菜单</text></view><view class="shopping-btn data-v-2dfe9fce" bindtap="{{k}}"><text class="shopping-icon data-v-2dfe9fce">🛒</text><text class="shopping-text data-v-2dfe9fce">购物清单</text></view><text wx:if="{{l}}" class="gen-hint data-v-2dfe9fce">已生成 · {{m}}</text></view><scroll-view scroll-y class="meal-scroll data-v-2dfe9fce" style="{{'height:' + r}}"><view wx:if="{{n}}" class="day-meals data-v-2dfe9fce"><view class="day-label bounce-in data-v-2dfe9fce"><text class="dl-date data-v-2dfe9fce">{{o}}</text><text class="dl-cal data-v-2dfe9fce">{{p}} kcal</text></view><view wx:for="{{q}}" wx:for-item="meal" wx:key="e" class="meal-section data-v-2dfe9fce" style="{{'animation-delay:' + meal.f + ';' + 'animation:slideUp .45s ease forwards;opacity:0'}}"><view class="meal-header data-v-2dfe9fce"><view class="mh-left data-v-2dfe9fce"><text class="mh-icon data-v-2dfe9fce">{{meal.a}}</text><text class="mh-title data-v-2dfe9fce">{{meal.b}}</text></view><text class="mh-cal data-v-2dfe9fce">{{meal.c}} kcal</text></view><view class="food-row data-v-2dfe9fce"><view wx:for="{{meal.d}}" wx:for-item="food" wx:key="d" class="food-card data-v-2dfe9fce" bindtap="{{food.e}}" style="{{'animation-delay:' + food.f + ';' + 'animation:popIn .4s cubic-bezier(.175,.885,.32,1.275) forwards;opacity:0'}}"><view class="fc-icon-wrap data-v-2dfe9fce"><text class="fc-icon data-v-2dfe9fce">{{food.a}}</text></view><text class="fc-name data-v-2dfe9fce">{{food.b}}</text><text class="fc-kcal data-v-2dfe9fce">{{food.c}} kcal</text></view></view></view></view><view wx:else class="empty-state scale-in data-v-2dfe9fce"><text class="empty-icon data-v-2dfe9fce">📅</text><text class="empty-title data-v-2dfe9fce">该日暂无菜单</text><text class="empty-hint data-v-2dfe9fce">点击上方「生成本周菜单」一键规划</text></view><view class="bottom-spacer data-v-2dfe9fce"></view></scroll-view></view>