<view class="{{['page', 'data-v-4cfae750', r && 'page-enter']}}"><view class="header fade-in data-v-4cfae750"><text class="header-title data-v-4cfae750">一周菜单</text><text class="header-sub data-v-4cfae750">点击日期查看 · 智能荤素搭配</text></view><view wx:if="{{a}}" class="spark-banner pop-in data-v-4cfae750" style="animation-delay:0.1s;opacity:0"><view class="spark-icon-wrap data-v-4cfae750"><text class="spark-emoji data-v-4cfae750">🔥</text></view><view class="spark-info data-v-4cfae750"><text class="spark-main data-v-4cfae750">{{b}}天连续互动</text><text class="spark-sub data-v-4cfae750">分享{{c}}天 · 打开{{d}}次</text></view><view wx:if="{{e}}" class="spark-badge data-v-4cfae750"><text class="badge-txt data-v-4cfae750">💎</text></view></view><view class="calendar-wrap slide-up data-v-4cfae750" style="animation-delay:0.08s"><view class="cal-nav data-v-4cfae750"><view class="nav-btn data-v-4cfae750" bindtap="{{f}}"><text class="nav-arrow data-v-4cfae750">◀</text><text class="nav-txt data-v-4cfae750">上一周</text></view><text class="cal-month data-v-4cfae750">{{g}}</text><view class="nav-btn data-v-4cfae750" bindtap="{{h}}"><text class="nav-txt data-v-4cfae750">下一周</text><text class="nav-arrow data-v-4cfae750">▶</text></view></view><view class="week-row data-v-4cfae750"><view wx:for="{{i}}" wx:for-item="d" wx:key="j" class="{{['day-cell', 'data-v-4cfae750', d.f && 'active', d.g && 'is-today', d.h && 'has-data', d.i && 'has-spark']}}" bindtap="{{d.k}}"><text class="day-week data-v-4cfae750">{{d.a}}</text><text class="day-num data-v-4cfae750">{{d.b}}</text><view wx:if="{{d.c}}" class="spark-icon data-v-4cfae750"><text class="si-txt data-v-4cfae750">🔥</text></view><view wx:elif="{{d.d}}" class="spark-icon double data-v-4cfae750"><text class="si-txt data-v-4cfae750">🔥🔥</text></view><view wx:if="{{d.e}}" class="dot-row data-v-4cfae750"><view class="nutri-dot b-dot data-v-4cfae750"></view><view class="nutri-dot l-dot data-v-4cfae750"></view><view class="nutri-dot d-dot data-v-4cfae750"></view></view></view></view></view><view class="action-bar pop-in data-v-4cfae750" style="animation-delay:0.15s"><view class="gen-btn data-v-4cfae750" bindtap="{{j}}"><text class="gen-icon data-v-4cfae750">✦</text><text class="gen-text data-v-4cfae750">生成本周菜单</text></view><text wx:if="{{k}}" class="gen-hint data-v-4cfae750">已生成 · {{l}}</text></view><scroll-view scroll-y class="meal-scroll data-v-4cfae750" style="{{'height:' + q}}"><view wx:if="{{m}}" class="day-meals data-v-4cfae750"><view class="day-label bounce-in data-v-4cfae750"><text class="dl-date data-v-4cfae750">{{n}}</text><text class="dl-cal data-v-4cfae750">{{o}} kcal</text></view><view wx:for="{{p}}" wx:for-item="meal" wx:key="e" class="meal-section data-v-4cfae750" style="animation:slideUp .45s ease forwards;animation-delay:calc(0.12s * mi);opacity:0"><view class="meal-header data-v-4cfae750"><view class="mh-left data-v-4cfae750"><text class="mh-icon data-v-4cfae750">{{meal.a}}</text><text class="mh-title data-v-4cfae750">{{meal.b}}</text></view><text class="mh-cal data-v-4cfae750">{{meal.c}} kcal</text></view><view class="food-row data-v-4cfae750"><view wx:for="{{meal.d}}" wx:for-item="food" wx:key="d" class="food-card data-v-4cfae750" bindtap="{{food.e}}" style="animation:popIn .4s cubic-bezier(.175,.885,.32,1.275) forwards;animation-delay:calc(0.18s + mi*0.06s + fi*0.05s);opacity:0"><view class="fc-icon-wrap data-v-4cfae750"><text class="fc-icon data-v-4cfae750">{{food.a}}</text></view><text class="fc-name data-v-4cfae750">{{food.b}}</text><text class="fc-kcal data-v-4cfae750">{{food.c}} kcal</text></view></view></view></view><view wx:else class="empty-state scale-in data-v-4cfae750"><text class="empty-icon data-v-4cfae750">📅</text><text class="empty-title data-v-4cfae750">该日暂无菜单</text><text class="empty-hint data-v-4cfae750">点击上方「生成本周菜单」一键规划</text></view><view class="bottom-spacer data-v-4cfae750"></view></scroll-view></view>