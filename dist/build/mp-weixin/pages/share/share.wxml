<view class="page data-v-7dd2faff"><view class="share-hero data-v-7dd2faff"><text class="hero-emoji data-v-7dd2faff">{{a}}</text><text wx:if="{{b}}" class="hero-text data-v-7dd2faff">{{c}} 给你分享了今日菜单！</text><text wx:else class="hero-text data-v-7dd2faff">已发送给 {{d}}</text><text wx:if="{{e}}" class="hero-sub data-v-7dd2faff">看看喜不喜欢，可以确认或调整哦~</text><text wx:else class="hero-sub data-v-7dd2faff">等待TA确认菜单...</text><text class="hero-time data-v-7dd2faff">{{f}}</text><view wx:if="{{g}}" class="refresh-hint data-v-7dd2faff"><text class="refresh-icon data-v-7dd2faff">🔄</text><text class="refresh-text data-v-7dd2faff" bindtap="{{h}}">刷新查看TA的操作</text></view></view><scroll-view scroll-y class="body-scroll data-v-7dd2faff" style="{{'height:' + t}}"><view wx:if="{{i}}" class="{{['status-bar', 'data-v-7dd2faff', k]}}"><text class="status-dot data-v-7dd2faff"></text><text class="status-text data-v-7dd2faff">{{j}}</text></view><view wx:if="{{l}}" class="loading-card data-v-7dd2faff"><text class="loading-icon data-v-7dd2faff">⏳</text><text class="loading-text data-v-7dd2faff">正在加载菜单...</text></view><block wx:else><view wx:for="{{m}}" wx:for-item="meal" wx:key="e" class="meal-section data-v-7dd2faff"><view class="meal-header data-v-7dd2faff"><text class="mh-icon data-v-7dd2faff">{{meal.a}}</text><text class="mh-title data-v-7dd2faff">{{meal.b}}</text><text class="mh-cal data-v-7dd2faff">{{meal.c}} kcal</text></view><view class="food-row data-v-7dd2faff"><view wx:for="{{meal.d}}" wx:for-item="food" wx:key="d" class="food-card data-v-7dd2faff" bindtap="{{food.e}}"><view class="fc-icon-wrap data-v-7dd2faff"><text class="fc-icon data-v-7dd2faff">{{food.a}}</text></view><text class="fc-name data-v-7dd2faff">{{food.b}}</text><text class="fc-kcal data-v-7dd2faff">{{food.c}} kcal</text></view></view></view><view wx:if="{{n}}" class="action-area data-v-7dd2faff"><view class="primary-btn data-v-7dd2faff" bindtap="{{o}}"><text class="btn-icon data-v-7dd2faff">✓</text><text class="btn-text data-v-7dd2faff">这个菜单不错，就它了！</text></view><view class="secondary-btn data-v-7dd2faff" bindtap="{{p}}"><text class="btn-icon data-v-7dd2faff">✎</text><text class="btn-text data-v-7dd2faff">我想换几道菜</text></view><view class="tertiary-btn data-v-7dd2faff" bindtap="{{q}}"><text class="btn-icon data-v-7dd2faff">↩</text><text class="btn-text data-v-7dd2faff">我也用这个菜单</text></view></view><view wx:else class="action-area data-v-7dd2faff"><view class="waiting-card data-v-7dd2faff"><text class="waiting-icon data-v-7dd2faff">⌛</text><text class="waiting-text data-v-7dd2faff">等待{{r}}查看并确认...</text><text class="waiting-hint data-v-7dd2faff">点击上方「刷新」查看最新状态</text></view><view class="secondary-btn data-v-7dd2faff" bindtap="{{s}}"><text class="btn-icon data-v-7dd2faff">↻</text><text class="btn-text data-v-7dd2faff">重新生成并发送</text></view></view></block><view class="bottom-spacer data-v-7dd2faff"></view></scroll-view></view>