<view class="page data-v-21ce0225"><view class="share-hero data-v-21ce0225"><text class="hero-emoji data-v-21ce0225">{{a}}</text><text wx:if="{{b}}" class="hero-text data-v-21ce0225">{{c}} 给你分享了今日菜谱！</text><text wx:else class="hero-text data-v-21ce0225">已发送给 {{d}}</text><text wx:if="{{e}}" class="hero-sub data-v-21ce0225">看看喜不喜欢，可以确认或调整哦~</text><text wx:else class="hero-sub data-v-21ce0225">等待TA确认菜谱...</text><text class="hero-time data-v-21ce0225">{{f}}</text><view wx:if="{{g}}" class="refresh-hint data-v-21ce0225"><text class="refresh-icon data-v-21ce0225">🔄</text><text class="refresh-text data-v-21ce0225" bindtap="{{h}}">刷新查看TA的操作</text></view></view><scroll-view scroll-y class="body-scroll data-v-21ce0225" style="{{'height:' + t}}"><view wx:if="{{i}}" class="{{['status-bar', 'data-v-21ce0225', k]}}"><text class="status-dot data-v-21ce0225"></text><text class="status-text data-v-21ce0225">{{j}}</text></view><view wx:if="{{l}}" class="loading-card data-v-21ce0225"><text class="loading-icon data-v-21ce0225">⏳</text><text class="loading-text data-v-21ce0225">正在加载菜谱...</text></view><block wx:else><view wx:for="{{m}}" wx:for-item="meal" wx:key="e" class="meal-section data-v-21ce0225"><view class="meal-header data-v-21ce0225"><text class="mh-icon data-v-21ce0225">{{meal.a}}</text><text class="mh-title data-v-21ce0225">{{meal.b}}</text><text class="mh-cal data-v-21ce0225">{{meal.c}} kcal</text></view><view class="food-row data-v-21ce0225"><view wx:for="{{meal.d}}" wx:for-item="food" wx:key="g" class="food-card data-v-21ce0225" bindtap="{{food.h}}"><view class="fc-icon-wrap data-v-21ce0225"><image wx:if="{{food.a}}" class="fc-img data-v-21ce0225" src="{{food.b}}" mode="aspectFill" binderror="{{food.c}}"></image><text wx:else class="fc-icon data-v-21ce0225">{{food.d}}</text></view><text class="fc-name data-v-21ce0225">{{food.e}}</text><text class="fc-kcal data-v-21ce0225">{{food.f}} kcal</text></view></view></view><view wx:if="{{n}}" class="action-area data-v-21ce0225"><view class="primary-btn data-v-21ce0225" bindtap="{{o}}"><text class="btn-icon data-v-21ce0225">✓</text><text class="btn-text data-v-21ce0225">这个菜谱不错，就它了！</text></view><view class="secondary-btn data-v-21ce0225" bindtap="{{p}}"><text class="btn-icon data-v-21ce0225">✎</text><text class="btn-text data-v-21ce0225">我想换几道菜</text></view><view class="tertiary-btn data-v-21ce0225" bindtap="{{q}}"><text class="btn-icon data-v-21ce0225">↩</text><text class="btn-text data-v-21ce0225">我也用这个菜谱</text></view></view><view wx:else class="action-area data-v-21ce0225"><view class="waiting-card data-v-21ce0225"><text class="waiting-icon data-v-21ce0225">⌛</text><text class="waiting-text data-v-21ce0225">等待{{r}}查看并确认...</text><text class="waiting-hint data-v-21ce0225">点击上方「刷新」查看最新状态</text></view><view class="secondary-btn data-v-21ce0225" bindtap="{{s}}"><text class="btn-icon data-v-21ce0225">↻</text><text class="btn-text data-v-21ce0225">重新生成并发送</text></view></view></block><view class="bottom-spacer data-v-21ce0225"></view></scroll-view></view>