<view class="container">
  <view class="date-selector">
    <view class="date-nav">
      <view class="nav-btn" bindtap="prevWeek">‹</view>
      <view class="week-display">{{weekDisplay}}</view>
      <view class="nav-btn" bindtap="nextWeek">›</view>
    </view>
  </view>

  <view class="week-tabs">
    <view class="tab-item {{currentDateIndex === index ? 'active' : ''}}" 
          wx:for="{{weekDays}}" 
          wx:key="date"
          bindtap="selectDate"
          data-index="{{index}}">
      <text class="tab-weekday">{{item.weekday}}</text>
      <text class="tab-date">{{item.day}}</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="meal-section" wx:for="{{mealSections}}" wx:key="type">
      <view class="meal-header">
        <text class="meal-type-name">{{item.name}}</text>
        <text class="meal-icon">{{item.icon}}</text>
      </view>
      
      <view class="meal-card" wx:if="{{item.menu}}">
        <view class="recipe-info" wx:if="{{!item.menu.is_eating_out}}">
          <view class="recipe-name">{{item.menu.recipe_name}}</view>
          <view class="recipe-meta">
            <text class="cuisine-type">{{item.menu.cuisine_type}}</text>
            <text class="nutrition-info" wx:if="{{item.nutrition}}">
              热量: {{item.nutrition.calories}}kcal
            </text>
          </view>
        </view>
        
        <view class="eating-out" wx:else>
          <text>不在家用餐</text>
        </view>
        
        <view class="meal-actions">
          <button class="action-btn small" size="mini" bindtap="viewRecipe" wx:if="{{!item.menu.is_eating_out}}" data-id="{{item.menu.recipe_id}}">详情</button>
          <button class="action-btn outline small" size="mini" bindtap="replaceRecipe" wx:if="{{!item.menu.is_eating_out}}" data-id="{{item.menu.id}}">换一个</button>
          <button class="action-btn outline small" size="mini" bindtap="toggleEatingOut" data-id="{{item.menu.id}}" data-eating-out="{{!item.menu.is_eating_out}}">
            {{item.menu.is_eating_out ? '在家吃' : '外出'}}
          </button>
        </view>
      </view>
      
      <view class="empty-meal" wx:else>
        <text class="empty-text">暂无安排</text>
        <button class="action-btn small" size="mini" bindtap="addRecipe">添加</button>
      </view>
    </view>
  </view>

  <view class="generate-btn-container">
    <button class="primary-btn generate-btn" bindtap="generateWeekMenu">
      生成本周菜单
    </button>
  </view>
</view>
