.container {
  padding-bottom: 40rpx;
}

.filter-section {
  background: white;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.type-tabs {
  white-space: nowrap;
  padding: 0 20rpx;
}

.type-tab {
  display: inline-block;
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 50rpx;
}

.type-tab.active {
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
  color: white;
}

.movie-list {
  padding: 0 20rpx;
}

.movie-item {
  display: flex;
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.movie-poster {
  width: 160rpx;
  height: 220rpx;
  background: #f0f0f0;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.movie-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.movie-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.movie-meta {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.movie-genre {
  font-size: 24rpx;
  color: #FF6B35;
  background: #fff5f0;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.movie-year {
  font-size: 24rpx;
  color: #999;
  padding: 6rpx 0;
}

.movie-rating {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.rating-star {
  font-size: 28rpx;
}

.rating-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF9800;
}

.movie-platform {
  font-size: 24rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
}
