<view class="container">
  <view class="recipe-header" wx:if="{{recipe}}">
    <view class="recipe-image">{{recipe.image_url || '🍽️'}}</view>
    <view class="recipe-title">{{recipe.name}}</view>
    <view class="recipe-tags">
      <text class="tag" wx:for="{{recipe.tags}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <view class="recipe-info" wx:if="{{recipe}}">
    <view class="info-item">
      <text class="info-icon">⏱️</text>
      <text class="info-text">{{recipe.cooking_time}}分钟</text>
    </view>
    <view class="info-item">
      <text class="info-icon">📊</text>
      <text class="info-text">{{recipe.difficulty}}</text>
    </view>
    <view class="info-item">
      <text class="info-icon">🌍</text>
      <text class="info-text">{{recipe.cuisine_type}}</text>
    </view>
  </view>

  <view class="nutrition-section" wx:if="{{recipe && recipe.nutrition}}">
    <view class="section-title">营养信息</view>
    <view class="nutrition-grid">
      <view class="nutrition-item">
        <text class="nutrition-value">{{recipe.nutrition.calories}}</text>
        <text class="nutrition-label">热量(kcal)</text>
      </view>
      <view class="nutrition-item">
        <text class="nutrition-value">{{recipe.nutrition.protein}}</text>
        <text class="nutrition-label">蛋白质(g)</text>
      </view>
      <view class="nutrition-item">
        <text class="nutrition-value">{{recipe.nutrition.fat}}</text>
        <text class="nutrition-label">脂肪(g)</text>
      </view>
      <view class="nutrition-item">
        <text class="nutrition-value">{{recipe.nutrition.carbs}}</text>
        <text class="nutrition-label">碳水(g)</text>
      </view>
    </view>
  </view>

  <view class="ingredients-section" wx:if="{{recipe}}">
    <view class="section-title">食材清单</view>
    <view class="ingredient-list">
      <view class="ingredient-item" wx:for="{{recipe.ingredients}}" wx:key="name">
        <text class="ingredient-name">{{item.name}}</text>
        <text class="ingredient-amount">{{item.amount}}</text>
      </view>
    </view>
  </view>

  <view class="steps-section" wx:if="{{recipe}}">
    <view class="section-title">制作步骤</view>
    <view class="step-item" wx:for="{{recipe.steps}}" wx:key="index">
      <view class="step-number">{{index + 1}}</view>
      <view class="step-content">{{item}}</view>
    </view>
  </view>

  <view class="movies-section" wx:if="{{relatedMovies.length > 0}}">
    <view class="section-title">推荐影视</view>
    <scroll-view class="movie-scroll" scroll-x="true">
      <view class="movie-card" wx:for="{{relatedMovies}}" wx:key="id">
        <view class="movie-poster">{{item.image_url || '🎬'}}</view>
        <view class="movie-info">
          <text class="movie-title">{{item.title}}</text>
          <text class="movie-rating">⭐ {{item.rating}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="feedback-section">
    <view class="section-title">评价反馈</view>
    <view class="rating-stars">
      <text class="star {{selectedRating >= 1 ? 'active' : ''}}" bindtap="selectRating" data-rating="1">★</text>
      <text class="star {{selectedRating >= 2 ? 'active' : ''}}" bindtap="selectRating" data-rating="2">★</text>
      <text class="star {{selectedRating >= 3 ? 'active' : ''}}" bindtap="selectRating" data-rating="3">★</text>
      <text class="star {{selectedRating >= 4 ? 'active' : ''}}" bindtap="selectRating" data-rating="4">★</text>
      <text class="star {{selectedRating >= 5 ? 'active' : ''}}" bindtap="selectRating" data-rating="5">★</text>
    </view>
    <textarea class="feedback-input" placeholder="分享你的想法..." value="{{feedbackText}}" bindinput="onFeedbackInput"></textarea>
    <button class="primary-btn submit-btn" bindtap="submitFeedback">提交评价</button>
  </view>
</view>
