<view class="container">
  <view class="header">
    <view class="header-left">
      <text class="app-title">吃点啥</text>
      <text class="date">{{currentDate}}</text>
    </view>
    <view class="user-info" bindtap="goToProfile">
      <text class="avatar">{{userInfo.nickname ? userInfo.nickname.charAt(0) : '美'}}</text>
    </view>
  </view>

  <view class="greeting-section">
    <text class="greeting">{{greeting}}</text>
    <van-button type="primary" size="small" round bindtap="showCountPicker">
      {{userCount}}人份
    </van-button>
  </view>

  <view class="section daily-meals-section">
    <view class="section-header">
      <text class="section-title">今日食谱</text>
      <text class="section-more" bindtap="goToMenu">查看全部</text>
    </view>

    <view class="meal-card" wx:for="{{dailyMeals}}" wx:key="title">
      <view class="meal-label">
        <text class="meal-icon">{{item.icon}}</text>
        <text class="meal-name">{{item.title}}</text>
      </view>
      
      <van-grid column-num="2" border="{{false}}" gutter="16">
        <van-grid-item wx:for="{{item.recipes}}" wx:for-item="recipe" wx:key="id" use-slot bindtap="viewMealRecipe" data-recipe="{{recipe}}">
          <view class="recipe-item">
            <view class="recipe-image-box">
              <text class="recipe-emoji">{{recipe.image || '🍽️'}}</text>
            </view>
            <view class="recipe-content">
              <text class="recipe-title">{{recipe.name}}</text>
              <van-tag type="primary" size="mini">{{recipe.calories * userCount}}kcal</van-tag>
            </view>
          </view>
        </van-grid-item>
      </van-grid>
    </view>
  </view>

  <view class="section quick-section">
    <view class="section-header">
      <text class="section-title">快捷功能</text>
    </view>
    <van-grid column-num="3" border="{{false}}" gutter="20">
      <van-grid-item use-slot bindtap="goToMenu">
        <view class="quick-item">
          <van-icon name="notes-o" size="48" />
          <text class="quick-text">全部菜单</text>
        </view>
      </van-grid-item>
      <van-grid-item use-slot bindtap="goToMovies">
        <view class="quick-item">
          <van-icon name="video-o" size="48" />
          <text class="quick-text">下饭影视</text>
        </view>
      </van-grid-item>
      <van-grid-item use-slot bindtap="goToProfile">
        <view class="quick-item">
          <van-icon name="setting-o" size="48" />
          <text class="quick-text">偏好设置</text>
        </view>
      </van-grid-item>
    </van-grid>
  </view>

  <van-action-sheet show="{{showCountPicker}}" bind:close="onClosePicker" title="选择用餐人数">
    <view class="picker-options">
      <view class="picker-option {{userCount === item ? 'active' : ''}}" 
            wx:for="{{userCountOptions}}" 
            wx:key="*this"
            bindtap="selectCount"
            data-count="{{item}}">
        {{item}}人份
      </view>
    </view>
  </van-action-sheet>

  <view class="modal-overlay" wx:if="{{showOnboardingModal}}" bindtap="closeOnboardingModal">
    <view class="modal-box" catchtap="stopPropagation">
      <text class="modal-title">让推荐更懂你</text>
      <text class="modal-desc">花10秒设置口味偏好，获得更精准的推荐</text>
      <view class="modal-actions">
        <van-button type="default" bindtap="closeOnboardingModal">稍后再说</van-button>
        <van-button type="primary" bindtap="openOnboarding">立即设置</van-button>
      </view>
    </view>
  </view>

  <view class="footer-space"></view>
</view>
