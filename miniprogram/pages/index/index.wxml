<view class="container">
  <view class="header">
    <view class="header-left">
      <text class="app-title">吃点啥</text>
      <text class="date">{{currentDate}}</text>
    </view>
    <view class="user-info" bindtap="goToProfile">
      <text class="avatar">{{userInfo.nickname ? userInfo.nickname.charAt(0) : '美'}}</text>
    </view>
  </view>

  <view class="greeting-section">
    <text class="greeting">{{greeting}}</text>
    <view class="count-picker" bindtap="showCountPicker">
      <text class="count-text">{{userCount}}人份</text>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">今日食谱</text>
      <text class="section-more" bindtap="goToMenu">查看全部</text>
    </view>

    <view class="meal-card" wx:for="{{dailyMeals}}" wx:key="title">
      <view class="meal-label">
        <text class="meal-icon">{{item.icon}}</text>
        <text class="meal-name">{{item.title}}</text>
      </view>
      
      <view class="recipe-grid">
        <view class="recipe-item" 
              wx:for="{{item.recipes}}" 
              wx:for-item="recipe" 
              wx:key="id"
              bindtap="viewMealRecipe"
              data-recipe="{{recipe}}">
          <view class="recipe-image-box">
            <text class="recipe-emoji">{{recipe.image || '🍽️'}}</text>
          </view>
          <view class="recipe-content">
            <text class="recipe-title">{{recipe.name}}</text>
            <text class="recipe-calories">{{recipe.calories * userCount}}kcal</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="section quick-section">
    <view class="section-header">
      <text class="section-title">快捷功能</text>
    </view>
    <view class="quick-grid">
      <view class="quick-item" bindtap="goToMenu">
        <text class="quick-icon">📋</text>
        <text class="quick-text">全部菜单</text>
      </view>
      <view class="quick-item" bindtap="goToMovies">
        <text class="quick-icon">🎬</text>
        <text class="quick-text">下饭影视</text>
      </view>
      <view class="quick-item" bindtap="goToProfile">
        <text class="quick-icon">⚙️</text>
        <text class="quick-text">偏好设置</text>
      </view>
    </view>
  </view>

  <view class="picker-mask" wx:if="{{showCountPicker}}" bindtap="hideCountPicker">
    <view class="picker-sheet" catchtap="stopPropagation">
      <view class="picker-header">
        <text class="picker-title">选择用餐人数</text>
      </view>
      <view class="picker-options">
        <view class="picker-option {{userCount === item ? 'active' : ''}}" 
              wx:for="{{userCountOptions}}" 
              wx:key="*this"
              bindtap="selectCount"
              data-count="{{item}}">
          {{item}}人份
        </view>
      </view>
      <view class="picker-footer">
        <view class="picker-btn" bindtap="hideCountPicker">确定</view>
      </view>
    </view>
  </view>

  <view class="footer-space"></view>
</view>
