/* 全局变量 - 国际化白色主题 */
page {
  --primary-color: #FF6B35;
  --primary-light: #FFF3E0;
  --secondary-color: #4A90E2;
  --success-color: #4CAF50;
  --warning-color: #FF9800;
  --error-color: #F44336;
  --text-primary: #1A1A1A;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --bg-primary: #FFFFFF;
  --bg-secondary: #F8F9FA;
  --bg-tertiary: #F0F0F0;
  --border-color: #E8E8E8;
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
}

/* 页面容器 */
.container {
  min-height: 100vh;
  background: var(--bg-secondary);
  padding-bottom: 40rpx;
}

/* 头部区域 */
.header {
  background: linear-gradient(135deg, var(--primary-color) 0%, #FF8C42 100%);
  padding: 60rpx 32rpx 80rpx;
  position: relative;
  border-radius: 0 0 var(--radius-xl) var(--radius-xl);
}

.header-content {
  position: relative;
  z-index: 1;
}

.greeting {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.date {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 400;
}

.weather-badge {
  position: absolute;
  top: 60rpx;
  right: 32rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  padding: 16rpx 24rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.weather-icon {
  font-size: 36rpx;
}

.weather-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 内容区块 */
.section {
  margin: 0 24rpx 24rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--text-tertiary);
  font-weight: 400;
}

.section-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.section-more,
.explain-btn {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 500;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-sm);
  transition: background 0.2s;
}

.section-more:active,
.explain-btn:active {
  background: var(--primary-light);
}

/* 菜谱卡片 */
.recipe-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.recipe-card {
  background: var(--bg-primary);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-md);
  overflow: hidden;
  transition: all 0.3s ease;
  position: relative;
}

.recipe-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

.recipe-card.exploration {
  border-color: var(--secondary-color);
  background: linear-gradient(135deg, #F0F7FF 0%, #FFFFFF 100%);
}

.explore-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: var(--secondary-color);
  padding: 8rpx 16rpx;
  border-radius: var(--radius-sm);
  z-index: 2;
}

.explore-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.recipe-main {
  display: flex;
  padding: 24rpx;
  gap: 20rpx;
}

.recipe-image {
  width: 140rpx;
  height: 140rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.recipe-emoji {
  font-size: 72rpx;
}

.recipe-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 12rpx;
}

.recipe-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.3;
}

.recipe-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  font-size: 22rpx;
  color: var(--text-secondary);
  background: var(--bg-secondary);
  padding: 6rpx 14rpx;
  border-radius: var(--radius-sm);
  font-weight: 500;
}

.recipe-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.meta-item {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.meta-dot {
  font-size: 24rpx;
  color: var(--text-tertiary);
  opacity: 0.5;
}

/* 推荐理由 */
.explanation-bar {
  background: linear-gradient(135deg, #E3F2FD 0%, #F0F7FF 100%);
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  border-top: 2rpx solid var(--border-color);
}

.explanation-icon {
  font-size: 28rpx;
}

.explanation-text {
  font-size: 26rpx;
  color: var(--secondary-color);
  font-weight: 500;
  flex: 1;
}

/* 反馈栏 */
.feedback-bar {
  padding: 20rpx 24rpx;
  border-top: 2rpx solid var(--border-color);
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--bg-secondary);
}

.feedback-hint {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.feedback-actions {
  display: flex;
  gap: 16rpx;
}

.feedback-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: var(--radius-md);
  background: var(--bg-primary);
  border: 2rpx solid var(--border-color);
  transition: all 0.2s;
}

.feedback-btn:active {
  transform: scale(0.95);
}

.feedback-btn.like.active {
  background: #FFEBEE;
  border-color: var(--error-color);
}

.feedback-btn.dislike:active {
  background: var(--bg-tertiary);
}

.btn-icon {
  font-size: 28rpx;
}

.btn-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.feedback-btn.like.active .btn-text {
  color: var(--error-color);
}

/* 探索统计 */
.explore-stats {
  margin-top: 24rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #F3E5F5 0%, #F0F7FF 100%);
  border-radius: var(--radius-md);
  text-align: center;
}

.stats-text {
  font-size: 26rpx;
  color: var(--secondary-color);
  font-weight: 500;
}

/* 今日三餐 */
.meal-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.meal-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-md);
  gap: 20rpx;
}

.meal-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, #FF8C42 100%);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.meal-icon {
  font-size: 40rpx;
}

.meal-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.meal-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.meal-recipe {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.meal-empty {
  font-size: 26rpx;
  color: var(--text-tertiary);
  font-style: italic;
}

.meal-action {
  flex-shrink: 0;
}

.action-link {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 600;
  padding: 12rpx 24rpx;
}

/* 快捷功能 */
.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 16rpx;
  border-radius: var(--radius-md);
  transition: all 0.2s;
}

.quick-item:active {
  transform: scale(0.95);
  background: var(--bg-secondary);
}

.quick-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: var(--shadow-sm);
}

.quick-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* 影视推荐 */
.movie-scroll {
  white-space: nowrap;
  margin: 0 -32rpx;
  padding: 0 32rpx;
}

.movie-card {
  display: inline-flex;
  flex-direction: column;
  width: 240rpx;
  margin-right: 20rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.movie-poster {
  width: 240rpx;
  height: 320rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
}

.movie-info {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.movie-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.movie-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.movie-rating {
  font-size: 24rpx;
  color: var(--warning-color);
  font-weight: 600;
}

.movie-genre {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* 弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(8rpx);
}

.modal-box {
  width: 560rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-xl);
  padding: 48rpx 40rpx;
  box-shadow: var(--shadow-lg);
}

.modal-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.modal-emoji {
  font-size: 80rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.modal-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.btn-primary,
.btn-secondary {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius-md);
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-color) 0%, #FF8C42 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 53, 0.2);
}

.btn-secondary {
  background: var(--bg-secondary);
  color: var(--text-secondary);
  border: 2rpx solid var(--border-color);
}

.btn-secondary:active {
  background: var(--bg-tertiary);
}

/* 偏好更新提示 */
.preference-toast {
  position: fixed;
  top: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  padding: 20rpx 40rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: var(--shadow-md);
  z-index: 999;
}

.toast-icon {
  font-size: 32rpx;
}

.toast-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 底部留白 */
.footer-space {
  height: 40rpx;
}

/* 响应式优化 */
@media (prefers-color-scheme: dark) {
  page {
    --bg-primary: #1A1A1A;
    --bg-secondary: #2D2D2D;
    --bg-tertiary: #3D3D3D;
    --text-primary: #FFFFFF;
    --text-secondary: #B0B0B0;
    --text-tertiary: #808080;
    --border-color: #404040;
  }
}
