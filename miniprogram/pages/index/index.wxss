page {
  background: #f5f5f5;
}

.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.header {
  background: #ffffff;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.app-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 8rpx;
}

.date {
  font-size: 28rpx;
  color: #999999;
}

.user-info {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 600;
}

.greeting-section {
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.greeting {
  font-size: 32rpx;
  color: #333333;
}

.count-picker {
  background: #07c160;
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.count-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
}

.arrow {
  color: #ffffff;
  font-size: 20rpx;
}

.section {
  margin: 24rpx 0;
}

.section-header {
  padding: 0 32rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.section-more {
  font-size: 28rpx;
  color: #999999;
}

.meal-card {
  background: #ffffff;
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
}

.meal-label {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.meal-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.meal-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.recipe-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.recipe-item {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 20rpx;
}

.recipe-image-box {
  width: 88rpx;
  height: 88rpx;
  background: #ffffff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.recipe-emoji {
  font-size: 48rpx;
}

.recipe-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.recipe-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recipe-calories {
  font-size: 24rpx;
  color: #07c160;
  font-weight: 500;
}

.quick-section {
  padding: 0 32rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 20rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 20rpx;
}

.quick-icon {
  font-size: 48rpx;
}

.quick-text {
  font-size: 24rpx;
  color: #333333;
}

.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.picker-sheet {
  background: #ffffff;
  width: 100%;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
}

.picker-header {
  text-align: center;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.picker-options {
  max-height: 500rpx;
  overflow-y: auto;
}

.picker-option {
  padding: 32rpx;
  text-align: center;
  font-size: 32rpx;
  color: #333333;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
}

.picker-option.active {
  background: #e8f7ef;
  color: #07c160;
  font-weight: 600;
}

.picker-footer {
  padding-top: 32rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 24rpx;
}

.picker-btn {
  background: #07c160;
  color: #ffffff;
  text-align: center;
  padding: 28rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 32rpx;
}

.modal-box {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  width: 100%;
  max-width: 560rpx;
}

.modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
  margin-bottom: 16rpx;
}

.modal-desc {
  display: block;
  font-size: 28rpx;
  color: #999999;
  text-align: center;
  margin-bottom: 48rpx;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 28rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.modal-btn-secondary {
  background: #f5f5f5;
  color: #333333;
}

.modal-btn-primary {
  background: #07c160;
  color: #ffffff;
}

.footer-space {
  height: 40rpx;
}
