.container {
  padding-bottom: 40rpx;
}

.header {
  padding: 30rpx 0;
}

.greeting-text {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.date-text {
  font-size: 28rpx;
  color: #999;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #FF6B35;
}

.today-menu {
  margin-bottom: 40rpx;
}

.meal-list {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
}

.meal-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.meal-item:last-child {
  border-bottom: none;
}

.meal-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.meal-info {
  flex: 1;
}

.meal-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.meal-recipe {
  font-size: 26rpx;
  color: #999;
}

.action-btn {
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
  color: white;
  border: none;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}

.quick-actions {
  margin-bottom: 40rpx;
}

.action-grid {
  display: flex;
  justify-content: space-around;
  background: white;
  border-radius: 16rpx;
  padding: 40rpx 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff5f0;
  border-radius: 50%;
}

.action-text {
  font-size: 26rpx;
  color: #333;
}

.recommended-movies {
  margin-bottom: 40rpx;
}

.movie-scroll {
  white-space: nowrap;
}

.movie-item {
  display: inline-block;
  width: 200rpx;
  margin-right: 20rpx;
  background: white;
  border-radius: 12rpx;
  overflow: hidden;
}

.movie-poster {
  width: 200rpx;
  height: 280rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.movie-info {
  padding: 16rpx 12rpx;
}

.movie-title {
  font-size: 26rpx;
  color: #333;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 6rpx;
}

.movie-rating {
  font-size: 24rpx;
  color: #FF9800;
}

.personalized-recommendations {
  margin-bottom: 40rpx;
}

.why-btn {
  font-size: 24rpx;
  color: #FF6B35;
}

.recipe-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.recipe-main {
  display: flex;
}

.recipe-emoji {
  width: 100rpx;
  height: 100rpx;
  background: #fff5f0;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.recipe-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.recipe-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.recipe-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.tag-small {
  font-size: 20rpx;
  color: #FF6B35;
  background: #fff5f0;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.recipe-meta {
  display: flex;
  gap: 16rpx;
}

.cuisine, .time, .calories {
  font-size: 22rpx;
  color: #999;
}

.reason-section {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.reason-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.recipe-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 16rpx;
}

.action-like, .action-dislike {
  font-size: 32rpx;
  background: transparent;
  border: none;
  padding: 8rpx 16rpx;
  line-height: 1;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-content {
  width: 560rpx;
  background: white;
  border-radius: 24rpx;
  padding: 60rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.btn-skip, .btn-start {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  border: none;
}

.btn-skip {
  background: #f5f5f5;
  color: #666;
}

.btn-start {
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
  color: white;
}

