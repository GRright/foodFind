<view class="container">
  <view class="date-header">
    <view class="date-nav">
      <view class="nav-btn" bindtap="prevWeek">‹</view>
      <view class="week-display">{{weekDisplay}}</view>
      <view class="nav-btn" bindtap="nextWeek">›</view>
    </view>
  </view>

  <view class="week-tabs">
    <view class="tab-item {{currentDateIndex === index ? 'active' : ''}}" 
          wx:for="{{weekDays}}" 
          wx:key="date"
          bindtap="selectDate"
          data-index="{{index}}">
      <text class="tab-weekday">{{item.weekday}}</text>
      <text class="tab-date">{{item.day}}</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="meal-item" wx:for="{{mealSections}}" wx:key="type">
      <view class="meal-label">
        <text class="meal-icon">{{item.icon}}</text>
        <text class="meal-name">{{item.name}}</text>
      </view>
      
      <view class="meal-card" wx:if="{{item.menu}}">
        <view class="recipe-content" wx:if="{{!item.menu.is_eating_out}}">
          <text class="recipe-name">{{item.menu.recipe_name}}</text>
          <view class="recipe-meta">
            <text class="meta-tag">{{item.menu.cuisine_type}}</text>
            <text class="meta-cal" wx:if="{{item.nutrition}}">{{item.nutrition.calories}}kcal</text>
          </view>
        </view>
        
        <view class="eating-out" wx:else>
          <text class="eating-out-text">不在家用餐</text>
        </view>
        
        <view class="meal-actions">
          <button class="action-btn" wx:if="{{!item.menu.is_eating_out}}" bindtap="viewRecipe" data-id="{{item.menu.recipe_id}}">详情</button>
          <button class="action-btn outline" wx:if="{{!item.menu.is_eating_out}}" bindtap="replaceRecipe" data-id="{{item.menu.id}}">换一个</button>
          <button class="action-btn outline" bindtap="toggleEatingOut" data-id="{{item.menu.id}}" data-eating-out="{{!item.menu.is_eating_out}}">
            {{item.menu.is_eating_out ? '在家吃' : '外出'}}
          </button>
        </view>
      </view>
      
      <view class="empty-card" wx:else>
        <text class="empty-text">暂无安排</text>
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <button class="generate-btn" bindtap="generateWeekMenu">生成本周菜单</button>
  </view>
</view>
