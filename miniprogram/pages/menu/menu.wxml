<view class="container">
  <view class="date-header">
    <van-button icon="arrow-left" size="small" bindtap="prevWeek" />
    <text class="week-display">{{weekDisplay}}</text>
    <van-button icon="arrow" size="small" bindtap="nextWeek" />
  </view>

  <van-tabs active="{{currentDateIndex}}" bind:change="onTabChange" color="#07c160">
    <van-tab wx:for="{{weekDays}}" wx:key="date" title="{{item.weekday}}">{{item.day}}日</van-tab>
  </van-tabs>

  <view class="menu-section">
    <view class="meal-item" wx:for="{{mealSections}}" wx:key="type">
      <view class="meal-label">
        <text class="meal-icon">{{item.icon}}</text>
        <text class="meal-name">{{item.name}}</text>
      </view>
      
      <van-cell-group inset wx:if="{{item.menus && item.menus.length > 0}}">
        <van-cell 
          wx:for="{{item.menus}}" 
          wx:for-item="menu"
          wx:key="id"
          title="{{menu.recipe_name}}"
          is-link
          bindtap="viewRecipe"
          data-id="{{menu.recipe_id}}">
          <van-tag slot="label" type="primary" size="mini">{{menu.cuisine_type}}</van-tag>
          <van-tag slot="right-icon" type="success" size="mini" wx:if="{{menu.nutrition}}">{{menu.nutrition.calories}}kcal</van-tag>
        </van-cell>
      </van-cell-group>
      
      <view class="empty-card" wx:else>
        <text class="empty-text">暂无安排</text>
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <van-button type="primary" size="large" block bindtap="generateWeekMenu">生成本周菜单</van-button>
  </view>
</view>
