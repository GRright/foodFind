<view class="container">
  <view class="date-header">
    <view class="nav-btn" bindtap="prevWeek">◀</view>
    <text class="week-display">{{weekDisplay}}</text>
    <view class="nav-btn" bindtap="nextWeek">▶</view>
  </view>

  <view class="tabs">
    <view class="tab-item {{currentDateIndex === index ? 'active' : ''}}" 
          wx:for="{{weekDays}}" 
          wx:key="date" 
          bindtap="selectDate"
          data-index="{{index}}">
      <text class="tab-weekday">{{item.weekday}}</text>
      <text class="tab-day">{{item.day}}</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="meal-item" wx:for="{{mealSections}}" wx:key="type">
      <view class="meal-label">
        <text class="meal-icon">{{item.icon}}</text>
        <text class="meal-name">{{item.name}}</text>
      </view>
      
      <view class="recipe-list" wx:if="{{item.menus && item.menus.length > 0}}">
        <view class="recipe-item" 
              wx:for="{{item.menus}}" 
              wx:for-item="menu"
              wx:key="id"
              bindtap="viewRecipe"
              data-id="{{menu.recipe_id}}">
          <text class="recipe-name">{{menu.recipe_name}}</text>
          <view class="recipe-meta">
            <text class="meta-item">{{menu.cuisine_type}}</text>
            <text class="meta-dot">·</text>
            <text class="meta-item" wx:if="{{menu.nutrition}}">{{menu.nutrition.calories}}kcal</text>
          </view>
        </view>
      </view>
      
      <view class="empty-card" wx:else>
        <text class="empty-text">暂无安排</text>
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <view class="generate-btn" bindtap="generateWeekMenu">生成本周菜单</view>
  </view>
</view>
