page {
  background: #FFFFFF;
}

.container {
  min-height: 100vh;
  padding-bottom: 160rpx;
}

.date-header {
  padding: 32rpx 32rpx 16rpx;
}

.date-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-btn {
  font-size: 44rpx;
  font-weight: 300;
  color: #007AFF;
  padding: 8rpx 16rpx;
}

.week-display {
  font-size: 28rpx;
  color: #1A1A1A;
  font-weight: 500;
}

.week-tabs {
  display: flex;
  padding: 16rpx 24rpx;
  gap: 8rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.tab-item.active {
  background: #F5F5F7;
}

.tab-weekday {
  font-size: 22rpx;
  color: #8E8E93;
  margin-bottom: 6rpx;
}

.tab-item.active .tab-weekday {
  color: #007AFF;
}

.tab-date {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.tab-item.active .tab-date {
  color: #007AFF;
}

.menu-section {
  padding: 0 32rpx;
}

.meal-item {
  margin-bottom: 24rpx;
}

.meal-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.meal-icon {
  font-size: 32rpx;
}

.meal-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.meal-card,
.empty-card {
  background: #F5F5F7;
  border-radius: 20rpx;
  padding: 28rpx;
}

.recipe-content {
  margin-bottom: 20rpx;
}

.recipe-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.recipe-meta {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.meta-tag {
  font-size: 24rpx;
  color: #007AFF;
  background: rgba(0, 122, 255, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.meta-cal {
  font-size: 24rpx;
  color: #8E8E93;
}

.eating-out {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.eating-out-text {
  font-size: 28rpx;
  color: #8E8E93;
}

.meal-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  background: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #1A1A1A;
  line-height: 72rpx;
  padding: 0;
}

.action-btn::after {
  border: none;
}

.action-btn.outline {
  background: transparent;
  border: 1rpx solid #D1D1D6;
  color: #007AFF;
}

.empty-card {
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-text {
  font-size: 28rpx;
  color: #8E8E93;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #F5F5F7;
}

.generate-btn {
  width: 100%;
  height: 92rpx;
  background: #007AFF;
  border: none;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  line-height: 92rpx;
  padding: 0;
}

.generate-btn::after {
  border: none;
}
