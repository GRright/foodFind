page {
  background: #f5f5f5;
}

.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.date-header {
  background: #ffffff;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333333;
}

.week-display {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.tabs {
  background: #ffffff;
  display: flex;
  padding: 16rpx 32rpx;
  gap: 16rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
}

.tab-item.active {
  background: #e8f7ef;
}

.tab-weekday {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.tab-item.active .tab-weekday {
  color: #07c160;
}

.tab-day {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.tab-item.active .tab-day {
  color: #07c160;
}

.menu-section {
  padding: 32rpx 0;
}

.meal-item {
  margin: 0 32rpx 24rpx;
}

.meal-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.meal-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.meal-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.recipe-list {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.recipe-item {
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.recipe-item:last-child {
  border-bottom: none;
}

.recipe-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.recipe-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #999999;
}

.meta-dot {
  color: #e0e0e0;
  font-size: 20rpx;
}

.empty-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 64rpx;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.bottom-bar {
  padding: 32rpx;
}

.generate-btn {
  background: #07c160;
  color: #ffffff;
  text-align: center;
  padding: 28rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
}
