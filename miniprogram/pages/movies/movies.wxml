<view class="container">
  <van-tabs active="{{currentTypeIndex}}" bind:change="onTypeChange" color="#07c160">
    <van-tab wx:for="{{movieTypes}}" wx:key="value" title="{{item.label}}"></van-tab>
  </van-tabs>

  <view class="movie-list">
    <van-card
      wx:for="{{filteredMovies}}"
      wx:key="id"
      title="{{item.title}}"
      thumb="{{item.thumb || ''}}"
      desc="{{item.genre}} · {{item.year}}"
      price="{{item.rating}}"
      currency="★"
      bindtap="viewMovie"
      data-id="{{item.id}}"
    >
      <van-tag slot="tag" type="primary" size="mini">{{item.platform}}</van-tag>
      <view slot="thumb" class="movie-thumb">
        <text class="thumb-icon">{{item.icon}}</text>
      </view>
    </van-card>
  </view>

  <view class="footer-space"></view>
</view>
