<view class="container">
  <view class="tabs">
    <view class="tab-item {{currentTypeIndex === index ? 'active' : ''}}" 
          wx:for="{{movieTypes}}" 
          wx:key="value"
          bindtap="selectType"
          data-type="{{item.value}}"
          data-index="{{index}}">
      {{item.label}}
    </view>
  </view>

  <view class="movie-list">
    <view class="movie-card" 
          wx:for="{{filteredMovies}}" 
          wx:key="id"
          bindtap="viewMovie"
          data-id="{{item.id}}">
      <view class="movie-icon">{{item.icon}}</view>
      <view class="movie-info">
        <text class="movie-title">{{item.title}}</text>
        <text class="movie-desc">{{item.genre}} · {{item.year}}</text>
        <view class="movie-meta">
          <text class="movie-rating">★ {{item.rating}}</text>
          <text class="movie-platform">{{item.platform}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="footer-space"></view>
</view>
