page {
  background: #FFFFFF;
}

.container {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.header {
  padding: 80rpx 32rpx 32rpx;
}

.page-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #1A1A1A;
  letter-spacing: -1rpx;
}

.filter-row {
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.type-scroll {
  width: 100%;
}

.type-list {
  display: flex;
  gap: 12rpx;
  white-space: nowrap;
}

.type-item {
  padding: 16rpx 32rpx;
  background: #F5F5F7;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #8E8E93;
  font-weight: 500;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.type-item.active {
  background: #007AFF;
  color: #FFFFFF;
}

.movie-list {
  padding: 0 32rpx;
}

.movie-card {
  display: flex;
  background: #F5F5F7;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  transition: all 0.2s ease;
}

.movie-card:active {
  transform: scale(0.98);
}

.movie-poster {
  width: 152rpx;
  height: 216rpx;
  background: #E5E5EA;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.poster-icon {
  font-size: 64rpx;
}

.movie-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.movie-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  line-height: 1.3;
  margin-bottom: 12rpx;
}

.movie-meta {
  display: flex;
  gap: 12rpx;
  align-items: center;
  margin-bottom: 16rpx;
}

.meta-tag {
  font-size: 24rpx;
  color: #007AFF;
  background: rgba(0, 122, 255, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.meta-year {
  font-size: 24rpx;
  color: #8E8E93;
}

.movie-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.rating-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.star {
  font-size: 24rpx;
  color: #FF9500;
}

.rating {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.platform {
  font-size: 24rpx;
  color: #8E8E93;
}

.footer-space {
  height: 40rpx;
}
