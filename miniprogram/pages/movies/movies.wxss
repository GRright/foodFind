page {
  background: #f5f5f5;
}

.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.tabs {
  background: #ffffff;
  display: flex;
  padding: 16rpx 32rpx;
  gap: 16rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 8rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  font-size: 28rpx;
  color: #333333;
}

.tab-item.active {
  background: #e8f7ef;
  color: #07c160;
  font-weight: 600;
}

.movie-list {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.movie-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  gap: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.movie-icon {
  font-size: 80rpx;
  width: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.movie-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.movie-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.movie-desc {
  font-size: 26rpx;
  color: #999999;
}

.movie-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.movie-rating {
  font-size: 28rpx;
  color: #07c160;
  font-weight: 600;
}

.movie-platform {
  font-size: 24rpx;
  color: #999999;
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.footer-space {
  height: 40rpx;
}
