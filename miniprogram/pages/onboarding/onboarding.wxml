<view class="container">
  <view class="header">
    <text class="title">让我们了解你</text>
    <text class="subtitle">这样推荐会更符合你的口味</text>
    
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progress}}%"></view>
    </view>
    <text class="step-text">{{currentStep + 1}} / {{totalSteps}}</text>
  </view>

  <view class="question-card" wx:if="{{currentQuestion}}">
    <text class="question-text">{{currentQuestion.question}}</text>
    
    <van-cell-group inset wx:if="{{currentQuestion.type === 'single_choice'}}">
      <van-cell 
        wx:for="{{currentQuestion.options}}" 
        wx:key="value"
        title="{{item.label}}"
        is-link="{{false}}"
        bindtap="selectSingleOption"
        data-value="{{item.value}}"
        class="{{selectedAnswer === item.value ? 'active-cell' : ''}}">
        <van-radio slot="right-icon" name="{{item.value}}" checked="{{selectedAnswer === item.value}}" />
      </van-cell>
    </van-cell-group>
    
    <van-cell-group inset wx:if="{{currentQuestion.type === 'multi_choice'}}">
      <van-cell 
        wx:for="{{currentQuestion.options}}" 
        wx:key="value"
        title="{{item.label}}"
        is-link="{{false}}"
        bindtap="toggleMultiOption"
        data-value="{{item.value}}"
        class="{{selectedAnswers.includes(item.value) ? 'active-cell' : ''}}">
        <van-checkbox slot="right-icon" name="{{item.value}}" checked="{{selectedAnswers.includes(item.value)}}" />
      </van-cell>
    </van-cell-group>
  </view>

  <view class="footer">
    <view class="btn-wrap" wx:if="{{currentStep > 0}}">
      <van-button type="default" size="large" bindtap="prevStep">上一步</van-button>
    </view>
    <view class="btn-wrap">
      <van-button type="primary" size="large" bindtap="handleNext" disabled="{{!canProceed}}">
        {{currentStep === totalSteps - 1 ? '完成' : '下一步'}}
      </van-button>
    </view>
  </view>
</view>
