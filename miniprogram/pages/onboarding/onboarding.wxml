<view class="container">
  <view class="header">
    <text class="title">让我们了解你</text>
    <text class="subtitle">这样推荐会更符合你的口味</text>
    
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progress}}%"></view>
    </view>
    <text class="step-text">{{currentStep + 1}} / {{totalSteps}}</text>
  </view>

  <view class="question-card" wx:if="{{currentQuestion}}">
    <text class="question-text">{{currentQuestion.question}}</text>
    
    <view class="options" wx:if="{{currentQuestion.type === 'single_choice'}}">
      <view class="option {{selectedAnswer === option.value ? 'active' : ''}}" 
            wx:for="{{currentQuestion.options}}" 
            wx:key="value"
            bindtap="selectSingleOption"
            data-value="{{option.value}}">
        <view class="option-dot">
          <view class="dot-inner" wx:if="{{selectedAnswer === option.value}}"></view>
        </view>
        <text class="option-label">{{option.label}}</text>
      </view>
    </view>
    
    <view class="options" wx:if="{{currentQuestion.type === 'multi_choice'}}">
      <view class="option {{selectedAnswers.includes(option.value) ? 'active' : ''}}" 
            wx:for="{{currentQuestion.options}}" 
            wx:key="value"
            bindtap="toggleMultiOption"
            data-value="{{option.value}}">
        <view class="option-box">
          <text class="check-icon" wx:if="{{selectedAnswers.includes(option.value)}}">✓</text>
        </view>
        <text class="option-label">{{option.label}}</text>
      </view>
    </view>
  </view>

  <view class="footer">
    <view class="btn-wrap" wx:if="{{currentStep > 0}}">
      <view class="btn btn-secondary" bindtap="prevStep">上一步</view>
    </view>
    <view class="btn-wrap">
      <view class="btn btn-primary {{!canProceed ? 'disabled' : ''}}" bindtap="handleNext">
        {{currentStep === totalSteps - 1 ? '完成' : '下一步'}}
      </view>
    </view>
  </view>
</view>
