page {
  background: #f7f8fa;
}

.container {
  min-height: 100vh;
  padding: 40rpx 32rpx 120rpx;
  display: flex;
  flex-direction: column;
}

.header {
  margin-bottom: 48rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #323233;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #969799;
  margin-bottom: 40rpx;
}

.progress-bar {
  height: 8rpx;
  background: #ebedf0;
  border-radius: 4rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #07c160;
  border-radius: 4rpx;
  transition: width 0.3s;
}

.step-text {
  font-size: 24rpx;
  color: #969799;
  text-align: right;
}

.question-card {
  flex: 1;
}

.question-text {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #323233;
  margin-bottom: 32rpx;
}

.active-cell {
  background: #e8f7ef !important;
}

.active-cell .van-cell__title {
  color: #07c160 !important;
  font-weight: 600 !important;
}

.footer {
  display: flex;
  gap: 20rpx;
  margin-top: auto;
  padding-top: 40rpx;
}

.btn-wrap {
  flex: 1;
}
