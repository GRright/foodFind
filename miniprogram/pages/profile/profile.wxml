<view class="container">
  <view class="header">
    <view class="user-card">
      <view class="avatar">
        <text class="avatar-text">{{userInfo.nickname ? userInfo.nickname.charAt(0) : '美'}}</text>
      </view>
      <view class="user-details">
        <text class="nickname">{{userInfo.nickname || '美食爱好者'}}</text>
        <text class="user-id">享受美食，享受生活</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="menu-list">
      <view class="menu-item" bindtap="goToPreferences">
        <text class="menu-icon">⚙️</text>
        <text class="menu-text">偏好设置</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToFavorites">
        <text class="menu-icon">❤️</text>
        <text class="menu-text">我的收藏</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToHistory">
        <text class="menu-icon">📜</text>
        <text class="menu-text">历史记录</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="menu-list">
      <view class="menu-item" bindtap="about">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于我们</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="feedback">
        <text class="menu-icon">💬</text>
        <text class="menu-text">意见反馈</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="footer">
    <text class="version">吃点啥 v1.0</text>
  </view>
</view>
