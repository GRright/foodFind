<view class="container">
  <view class="header">
    <view class="user-card">
      <view class="avatar">
        <text class="avatar-text">{{userInfo.nickname ? userInfo.nickname.charAt(0) : '美'}}</text>
      </view>
      <view class="user-details">
        <text class="nickname">{{userInfo.nickname || '美食爱好者'}}</text>
        <text class="user-id">享受美食，享受生活</text>
      </view>
    </view>
  </view>

  <view class="section">
    <van-cell-group inset>
      <van-cell title="偏好设置" is-link bindtap="goToPreferences">
        <view slot="icon" class="cell-icon">⚙️</view>
      </van-cell>
      <van-cell title="我的收藏" is-link bindtap="goToFavorites">
        <view slot="icon" class="cell-icon">❤️</view>
      </van-cell>
      <van-cell title="历史记录" is-link bindtap="goToHistory">
        <view slot="icon" class="cell-icon">📜</view>
      </van-cell>
    </van-cell-group>
  </view>

  <view class="section">
    <van-cell-group inset>
      <van-cell title="关于我们" is-link bindtap="about">
        <view slot="icon" class="cell-icon">ℹ️</view>
      </van-cell>
      <van-cell title="意见反馈" is-link bindtap="feedback">
        <view slot="icon" class="cell-icon">💬</view>
      </van-cell>
    </van-cell-group>
  </view>

  <view class="footer">
    <text class="version">吃点啥 v1.0</text>
  </view>
</view>
