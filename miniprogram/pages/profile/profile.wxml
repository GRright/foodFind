<view class="container">
  <view class="profile-header">
    <view class="avatar">{{userInfo.avatar ? '' : '👤'}}</view>
    <view class="user-info">
      <text class="nickname">{{userInfo.nickname || '美食爱好者'}}</text>
      <text class="user-id">ID: {{userId}}</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goToPreferences">
      <view class="menu-icon">⚙️</view>
      <text class="menu-text">偏好设置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToFavorites">
      <view class="menu-icon">❤️</view>
      <text class="menu-text">我的收藏</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToHistory">
      <view class="menu-icon">📜</view>
      <text class="menu-text">历史记录</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="preferences-section" wx:if="{{showPreferences}}">
    <view class="section-title">饮食偏好</view>
    
    <view class="preference-item">
      <text class="preference-label">饮食目标</text>
      <picker mode="selector" range="{{dietGoals}}" bindchange="onDietGoalChange" value="{{dietGoalIndex}}">
        <view class="picker-value">{{dietGoals[dietGoalIndex]}}</view>
      </picker>
    </view>

    <view class="preference-item">
      <text class="preference-label">口味偏好</text>
      <view class="tag-list">
        <view class="tag-item {{tastePreferences.indexOf(item) > -1 ? 'active' : ''}}" 
              wx:for="{{tasteOptions}}" 
              wx:key="*this"
              bindtap="toggleTaste"
              data-taste="{{item}}">
          {{item}}
        </view>
      </view>
    </view>

    <view class="preference-item">
      <text class="preference-label">过敏原</text>
      <view class="tag-list">
        <view class="tag-item {{allergies.indexOf(item) > -1 ? 'active' : ''}}" 
              wx:for="{{allergyOptions}}" 
              wx:key="*this"
              bindtap="toggleAllergy"
              data-allergy="{{item}}">
          {{item}}
        </view>
      </view>
    </view>

    <view class="section-title mt-40">影视偏好</view>
    
    <view class="preference-item">
      <text class="preference-label">喜欢的类型</text>
      <view class="tag-list">
        <view class="tag-item {{movieGenres.indexOf(item) > -1 ? 'active' : ''}}" 
              wx:for="{{movieGenreOptions}}" 
              wx:key="*this"
              bindtap="toggleMovieGenre"
              data-genre="{{item}}">
          {{item}}
        </view>
      </view>
    </view>

    <button class="primary-btn save-btn" bindtap="savePreferences">保存设置</button>
  </view>

  <view class="menu-section mt-40">
    <view class="menu-item" bindtap="about">
      <view class="menu-icon">ℹ️</view>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="feedback">
      <view class="menu-icon">💬</view>
      <text class="menu-text">意见反馈</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
