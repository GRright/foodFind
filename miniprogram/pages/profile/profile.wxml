<view class="container">
  <view class="header">
    <view class="user-card">
      <view class="avatar">
        <text class="avatar-text">{{userInfo.nickname ? userInfo.nickname.charAt(0) : '美'}}</text>
      </view>
      <view class="user-details">
        <text class="nickname">{{userInfo.nickname || '美食爱好者'}}</text>
        <text class="user-id">享受美食，享受生活</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">我的</view>
    <view class="list-card">
      <view class="list-item" wx:for="{{menuItems}}" wx:key="title" bindtap="{{item.action}}">
        <view class="item-left">
          <text class="item-icon">{{item.icon}}</text>
          <text class="item-title">{{item.title}}</text>
        </view>
        <text class="item-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">其他</view>
    <view class="list-card">
      <view class="list-item" wx:for="{{aboutItems}}" wx:key="title" bindtap="{{item.action}}">
        <view class="item-left">
          <text class="item-icon">{{item.icon}}</text>
          <text class="item-title">{{item.title}}</text>
        </view>
        <text class="item-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="footer">
    <text class="version">吃点啥 v1.0</text>
  </view>
</view>
