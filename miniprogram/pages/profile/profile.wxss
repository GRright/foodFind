page {
  background: #FFFFFF;
}

.container {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.header {
  padding: 80rpx 32rpx 40rpx;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #007AFF 0%, #5856D6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 44rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.user-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.user-id {
  font-size: 26rpx;
  color: #8E8E93;
}

.section {
  padding: 0 32rpx;
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #8E8E93;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  margin-bottom: 12rpx;
}

.list-card {
  background: #F5F5F7;
  border-radius: 20rpx;
  overflow: hidden;
}

.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 28rpx;
  transition: background 0.2s ease;
}

.list-item:active {
  background: rgba(0, 0, 0, 0.05);
}

.list-item + .list-item {
  border-top: 1rpx solid #E5E5EA;
}

.item-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.item-icon {
  font-size: 36rpx;
}

.item-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1A1A;
}

.item-arrow {
  font-size: 36rpx;
  color: #C7C7CC;
  font-weight: 300;
}

.footer {
  display: flex;
  justify-content: center;
  padding-top: 40rpx;
}

.version {
  font-size: 24rpx;
  color: #C7C7CC;
}
