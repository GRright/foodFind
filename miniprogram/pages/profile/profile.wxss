.container {
  padding-bottom: 40rpx;
}

.profile-header {
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
  padding: 60rpx 30rpx 40rpx;
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: white;
  display: block;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
}

.user-tier-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  border: 2rpx solid;
  backdrop-filter: blur(10rpx);
}

.tier-icon {
  font-size: 26rpx;
}

.tier-name {
  font-size: 22rpx;
  font-weight: 600;
}

/* 关键指标展示 */
.metrics-section {
  background: white;
  margin: 20rpx;
  padding: 30rpx 24rpx;
  border-radius: 16rpx;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.metric-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFFFFF 100%);
  border-radius: 12rpx;
}

.metric-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF6B35;
  margin-bottom: 8rpx;
}

.metric-label {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

/* 动态标签 */
.dynamic-tags-section {
  background: white;
  margin: 20rpx;
  padding: 30rpx 24rpx;
  border-radius: 16rpx;
}

.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.dynamic-tag {
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #FF6B35;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  border-radius: 50rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 53, 0.1);
}

/* 用户状态分析 */
.user-status-section {
  background: white;
  margin: 20rpx;
  padding: 30rpx 24rpx;
  border-radius: 16rpx;
}

.status-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-top: 24rpx;
}

.status-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  border: 2rpx solid;
  border-radius: 12rpx;
}

.status-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.status-name {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  text-align: center;
}

.status-desc {
  font-size: 22rpx;
  color: #666;
  text-align: center;
  line-height: 1.4;
}

.menu-section {
  background: white;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.preferences-section {
  background: white;
  margin: 20rpx;
  padding: 30rpx 24rpx;
  border-radius: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.mt-40 {
  margin-top: 40rpx;
}

.preference-item {
  margin-bottom: 32rpx;
}

.preference-item:last-child {
  margin-bottom: 0;
}

.preference-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.picker-value {
  font-size: 28rpx;
  color: #333;
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 50rpx;
  border: 2rpx solid transparent;
}

.tag-item.active {
  color: #FF6B35;
  background: #fff5f0;
  border-color: #FF6B35;
}

.save-btn {
  width: 100%;
  margin-top: 40rpx;
}
