<view class="container" wx:if="{{recipe}}">
  <view class="header">
    <view class="recipe-icon">{{recipe.image}}</view>
    <text class="recipe-name">{{recipe.name}}</text>
    <view class="tag-row">
      <van-tag wx:for="{{recipe.tags}}" wx:key="*this" type="primary" size="medium" plain>{{item}}</van-tag>
    </view>
  </view>

  <van-cell-group inset class="info-group">
    <van-cell title="⏱️ 烹饪时间" value="{{recipe.cooking_time}}分钟" is-link="{{false}}" />
    <van-cell title="📊 难度" value="{{recipe.difficulty}}" is-link="{{false}}" />
    <van-cell title="🌍 菜系" value="{{recipe.cuisine_type}}" is-link="{{false}}" />
  </van-cell-group>

  <view class="section">
    <view class="section-title">营养信息</view>
    <view class="nutrition-grid">
      <view class="nutrition-item">
        <text class="nutrition-value">{{recipe.nutrition.calories}}</text>
        <text class="nutrition-label">热量</text>
        <text class="nutrition-unit">kcal</text>
      </view>
      <view class="nutrition-item">
        <text class="nutrition-value">{{recipe.nutrition.protein}}</text>
        <text class="nutrition-label">蛋白质</text>
        <text class="nutrition-unit">g</text>
      </view>
      <view class="nutrition-item">
        <text class="nutrition-value">{{recipe.nutrition.fat}}</text>
        <text class="nutrition-label">脂肪</text>
        <text class="nutrition-unit">g</text>
      </view>
      <view class="nutrition-item">
        <text class="nutrition-value">{{recipe.nutrition.carbs}}</text>
        <text class="nutrition-label">碳水</text>
        <text class="nutrition-unit">g</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">食材清单</view>
    <van-cell-group inset>
      <van-cell 
        wx:for="{{recipe.ingredients}}" 
        wx:key="name"
        title="{{item.name}}"
        value="{{item.amount}}"
        is-link="{{false}}"
      />
    </van-cell-group>
  </view>

  <view class="section">
    <view class="section-title">制作步骤</view>
    <van-cell-group inset>
      <van-cell 
        wx:for="{{recipe.steps}}" 
        wx:key="index"
        title="步骤{{index + 1}}"
        label="{{item}}"
        is-link="{{false}}"
      />
    </van-cell-group>
  </view>

  <view class="section">
    <view class="section-title">评价这道菜</view>
    <view class="rating-section">
      <van-rate value="{{selectedRating}}" bind:change="onRateChange" />
      <textarea class="feedback-input" placeholder="分享你的想法..." value="{{feedbackText}}" bindinput="onFeedbackInput"></textarea>
      <van-button type="primary" size="large" block bindtap="submitFeedback">提交评价</van-button>
    </view>
  </view>

  <view class="footer-space"></view>
</view>
