.container {
  padding-bottom: 40rpx;
}

.recipe-header {
  background: white;
  padding: 30rpx 20rpx;
  text-align: center;
}

.recipe-image {
  width: 200rpx;
  height: 200rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  margin: 0 auto 24rpx;
}

.recipe-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.recipe-tags {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tag {
  font-size: 24rpx;
  color: #FF6B35;
  background: #fff5f0;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.recipe-info {
  display: flex;
  justify-content: space-around;
  background: white;
  margin: 20rpx;
  padding: 30rpx 20rpx;
  border-radius: 16rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.info-icon {
  font-size: 36rpx;
}

.info-text {
  font-size: 24rpx;
  color: #666;
}

.nutrition-section,
.ingredients-section,
.steps-section,
.movies-section,
.feedback-section {
  margin: 20rpx;
  background: white;
  padding: 30rpx 24rpx;
  border-radius: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.nutrition-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.nutrition-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 10rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.nutrition-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6B35;
  margin-bottom: 8rpx;
}

.nutrition-label {
  font-size: 22rpx;
  color: #999;
}

.ingredient-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ingredient-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.ingredient-item:last-child {
  border-bottom: none;
}

.ingredient-name {
  font-size: 28rpx;
  color: #333;
}

.ingredient-amount {
  font-size: 26rpx;
  color: #999;
}

.step-item {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.step-item:last-child {
  margin-bottom: 0;
}

.step-number {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  padding-top: 12rpx;
}

.movie-scroll {
  white-space: nowrap;
}

.movie-card {
  display: inline-block;
  width: 180rpx;
  margin-right: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  overflow: hidden;
}

.movie-poster {
  width: 180rpx;
  height: 240rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
}

.movie-info {
  padding: 12rpx;
}

.movie-title {
  font-size: 24rpx;
  color: #333;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 6rpx;
}

.movie-rating {
  font-size: 22rpx;
  color: #FF9800;
}

.rating-stars {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.star {
  font-size: 48rpx;
  color: #ddd;
  cursor: pointer;
}

.star.active {
  color: #FF9800;
}

.feedback-input {
  width: 100%;
  min-height: 150rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
}
