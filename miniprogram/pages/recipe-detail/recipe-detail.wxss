page {
  background: #f5f5f5;
}

.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.header {
  background: #ffffff;
  padding: 48rpx 32rpx;
  text-align: center;
}

.recipe-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 24rpx;
}

.recipe-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
  display: block;
  margin-bottom: 24rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
}

.tag {
  background: #e8f7ef;
  color: #07c160;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
}

.info-group {
  margin: 24rpx 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.info-item {
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 30rpx;
  color: #333333;
}

.info-value {
  font-size: 28rpx;
  color: #07c160;
  font-weight: 500;
}

.section {
  margin: 24rpx 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  padding: 0 32rpx 24rpx;
}

.nutrition-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 16rpx;
  padding: 0 32rpx;
}

.nutrition-item {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.nutrition-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #07c160;
}

.nutrition-label {
  font-size: 24rpx;
  color: #333333;
}

.nutrition-unit {
  font-size: 20rpx;
  color: #999999;
}

.ingredient-list {
  background: #ffffff;
  margin: 0 32rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.ingredient-item {
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.ingredient-item:last-child {
  border-bottom: none;
}

.ingredient-name {
  font-size: 30rpx;
  color: #333333;
}

.ingredient-amount {
  font-size: 28rpx;
  color: #07c160;
  font-weight: 500;
}

.step-list {
  background: #ffffff;
  margin: 0 32rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.step-item {
  padding: 32rpx;
  display: flex;
  gap: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.step-item:last-child {
  border-bottom: none;
}

.step-num {
  width: 56rpx;
  height: 56rpx;
  background: #e8f7ef;
  color: #07c160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.step-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

.footer-space {
  height: 40rpx;
}
