page {
  background: #FFFFFF;
}

.container {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.header {
  padding: 80rpx 32rpx 40rpx;
  text-align: center;
}

.recipe-icon {
  display: block;
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.recipe-name {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #1A1A1A;
  letter-spacing: -1rpx;
  margin-bottom: 20rpx;
}

.tag-row {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.tag {
  font-size: 24rpx;
  color: #007AFF;
  background: rgba(0, 122, 255, 0.08);
  padding: 8rpx 20rpx;
  border-radius: 50rpx;
  font-weight: 500;
}

.info-row {
  display: flex;
  justify-content: space-around;
  padding: 32rpx;
  background: #F5F5F7;
  margin: 0 32rpx 32rpx;
  border-radius: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.info-icon {
  font-size: 36rpx;
}

.info-text {
  font-size: 26rpx;
  color: #1A1A1A;
  font-weight: 500;
}

.info-divider {
  width: 1rpx;
  background: #E5E5EA;
}

.section {
  padding: 0 32rpx;
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 24rpx;
}

.nutrition-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.nutrition-item {
  background: #F5F5F7;
  border-radius: 16rpx;
  padding: 24rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nutrition-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #007AFF;
  margin-bottom: 6rpx;
}

.nutrition-label {
  font-size: 22rpx;
  color: #8E8E93;
  margin-bottom: 2rpx;
}

.nutrition-unit {
  font-size: 20rpx;
  color: #C7C7CC;
}

.ingredient-list {
  background: #F5F5F7;
  border-radius: 20rpx;
  padding: 8rpx 28rpx;
}

.ingredient-item {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E5E5EA;
}

.ingredient-item:last-child {
  border-bottom: none;
}

.ingredient-name {
  font-size: 28rpx;
  color: #1A1A1A;
  font-weight: 500;
}

.ingredient-amount {
  font-size: 26rpx;
  color: #8E8E93;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.step-item {
  display: flex;
  gap: 20rpx;
}

.step-num {
  width: 56rpx;
  height: 56rpx;
  background: #007AFF;
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.step-text {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A1A;
  line-height: 1.7;
  padding-top: 8rpx;
}

.rating-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.star {
  font-size: 52rpx;
  color: #E5E5EA;
  transition: color 0.2s ease;
}

.star.active {
  color: #FF9500;
}

.feedback-input {
  width: 100%;
  min-height: 160rpx;
  background: #F5F5F7;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  background: #007AFF;
  color: #FFFFFF;
  border: none;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 92rpx;
  padding: 0;
}

.submit-btn::after {
  border: none;
}

.footer-space {
  height: 40rpx;
}
